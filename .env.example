# Copy this file to .env and fill in real values.
# On Vercel, set these in Project Settings → Environment Variables instead.

PORT=5000
CLIENT_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:5000

# CompuLife API
COMPULIFE_DOMAIN=compulifeapi.com
COMPULIFE_AUTH_ID=your_compulife_auth_id
REMOTE_IP=your_whitelisted_ip

# Brevo (email) API key — used by /api/send-email
BREVO_API_KEY=your_brevo_api_key
